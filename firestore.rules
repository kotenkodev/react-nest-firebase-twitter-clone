rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
